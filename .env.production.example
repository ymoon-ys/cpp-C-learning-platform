# ============================================
# 阿里云服务器生产环境配置模板
# ============================================
# 
# 使用方法：
# 1. 复制此文件为 .env.production
# 2. 填写所有必需的配置项
# 3. 在服务器上运行时指定此文件
#
# ⚠️ 重要提示：
# - 不要将此文件提交到 Git
# - 密码和密钥必须使用强密码
# - 定期更换敏感信息

# ===== 应用基础配置（必填）=====

# Flask 密钥（用于 Session 加密，必须设置！）
# 生成方法: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-at-least-32-characters-long

# 运行环境
FLASK_ENV=production

# ===== 数据库配置（必填）=====

# 数据库类型：mysql 或 sqlite
DB_TYPE=mysql

# MySQL 连接信息（必填）
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_secure_password_here
MYSQL_DATABASE=learning_platform

# ===== AI 服务配置（选填）=====

# Ollama 本地/远程模型服务 URL
# 如果不配置，AI 助手功能将不可用
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3-coder:30b
OLLAMA_TIMEOUT=180

# 通义千问 API（阿里云免费额度）
# 推荐使用！免费 100万 tokens/月
# 获取地址：https://dashscope.console.aliyun.com/
AI_PROVIDER=qwen
QWEN_API_KEY=your_qwen_api_key_here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-turbo
QWEN_TIMEOUT=120

# 百度 OCR API（用于图片识别，可选）
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=

# ===== AI 功能配置（可选）=====

AI_MAX_HISTORY=20
AI_STREAM_ENABLED=true
AI_RATE_LIMIT=20 per minute

# ===== 编译器配置（可选）=====
# 通常不需要设置，Docker 镜像已包含 g++
# GPP_PATH=/usr/bin/g++

# ===== Gunicorn 配置（可选）=====
GUNICORN_WORKERS=2
GUNICORN_THREADS=4

# ===== 高级配置（一般无需修改）=====

# 上传文件大小限制（字节）
MAX_CONTENT_LENGTH=524288000

# 会话配置
PERMANENT_SESSION_LIFETIME_DAYS=7
